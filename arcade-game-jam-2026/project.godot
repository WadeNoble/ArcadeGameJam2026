[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="ground"
2d_physics/layer_3="player_projectiles"
2d_physics/layer_4="enemies"
2d_physics/layer_5="pickups"
2d_physics/layer_6="airborne_enemies"
2d_physics/layer_7="platforms"
2d_physics/layer_8="screen boundaries"
2d_physics/layer_9="enemy_hurtboxes"

[physics]

3d/physics_engine="Jolt Physics"
2d/default_gravity=690.0

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
